NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api
NEXT_PUBLIC_SOCKET_URL=https://your-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# Google sign-in ("Continue with Google" on login/signup). OAuth 2.0 Web
# client ID from https://console.cloud.google.com/apis/credentials — the same
# value as the backend's GOOGLE_CLIENT_ID. The frontend origin (localhost:3000
# and the deployed URL) must be listed under "Authorized JavaScript origins".
# Leave empty to hide the Google button entirely.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── SEO (all optional — sensible defaults are baked in) ──────────────
# Public origin used for canonical URLs, sitemap.xml, robots.txt, and
# Open Graph. Defaults to https://medihub-web.vercel.app; set this when
# the site moves to a custom domain.
NEXT_PUBLIC_SITE_URL=https://medihub-web.vercel.app
# Google Search Console "HTML tag" verification. The live site's token is
# baked into src/app/layout.tsx as the default — set this only to override
# it (e.g. a different Search Console property; see docs/SEO.md).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools "meta tag" verification (msvalidate.01 content value).
NEXT_PUBLIC_BING_SITE_VERIFICATION=