# Copy this file to backend/.env and update the values as needed.

# Server
PORT=5000

# PostgreSQL (Prisma) — matches the credentials in docker-compose.yml
DATABASE_URL="postgresql://medihub:medihub_secret@localhost:5432/medihub?schema=public"

# Auth — replace with a long random string before running
JWT_SECRET=change-me-to-a-long-random-string

# Ollama (optional — local AI assistant). Install from https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=smollm:1.7b

# External APIs (optional — events and news pages fall back to empty results without these)
EVENTBRITE_TOKEN=
NEWS_API_KEY=
