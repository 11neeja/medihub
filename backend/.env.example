# Copy this file to backend/.env and update the values as needed.

# Server
PORT=5000

# PostgreSQL (Prisma Postgres) — use the pooled connection string from the Prisma dashboard
DATABASE_URL="postgres://your-user:your-password@pooled.db.prisma.io:5432/postgres?sslmode=require"

# Optional direct connection for migrations or one-off admin scripts
DIRECT_URL="postgres://your-user:your-password@db.prisma.io:5432/postgres?sslmode=require"

# Auth — replace with a long random string before running
JWT_SECRET=change-me-to-a-long-random-string

# Frontend URL for email links (password reset, welcome).
# In production this MUST be the deployed frontend URL, or reset links break.
FRONTEND_URL=http://localhost:3000

# ── Mail delivery ─────────────────────────────────────────────────
# Two providers; either alone works, with both set Brevo is primary and
# Gmail SMTP is the automatic fallback.
#
# Brevo (recommended for production): sends over HTTPS, so it keeps working
# when Google blocks SMTP logins from cloud-host IPs (the usual reason Gmail
# mail "works locally but not on Render"). Free tier: 300 emails/day.
# Setup (~3 min): sign up at https://app.brevo.com → Senders: verify the
# SMTP_FROM_EMAIL address → Settings → API keys → create key → paste below.
BREVO_API_KEY=

# Gmail relay (Google Apps Script web app) — free, sends through the real
# Gmail account over HTTPS: best inbox deliverability, works from Render,
# ~100 recipients/day. Deploy backend/scripts/gmail-relay.gs at
# https://script.google.com (instructions in that file), then set:
GMAIL_RELAY_URL=
GMAIL_RELAY_SECRET=

# Which provider to try first (comma-separated). Default gmail-relay,brevo,smtp.
# gmail-relay: authenticated gmail.com mail straight to inboxes (small daily cap).
# brevo: no small cap, but the @<id>.brevosend.com rewrite gets 421-deferred by
# Gmail until a real domain is authenticated in Brevo.
# smtp: unreachable from Render (timeouts); put it first only for local dev.
MAIL_PROVIDER_ORDER=gmail-relay,brevo,smtp

# Gmail SMTP / Nodemailer
# Create an App Password at https://myaccount.google.com/apppasswords
# and paste it WITHOUT spaces (Gmail displays it as "xxxx xxxx xxxx xxxx").
# Changing the Google account password revokes ALL existing app passwords.
# Production note: these values live in the Render dashboard, NOT in this file.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FAMILY=4
SMTP_REQUIRE_TLS=true
SMTP_DEBUG=false
SMTP_CONNECTION_TIMEOUT=15000
SMTP_GREETING_TIMEOUT=15000
SMTP_SOCKET_TIMEOUT=20000
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=MediHub
SMTP_FROM_EMAIL=no-reply@medihub.com

# AI provider (production: gemini, local fallback: ollama)
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=smollm:1.7b

# External APIs (optional — events and news pages fall back to empty results without these)
EVENTBRITE_TOKEN=
NEWS_API_KEY=
