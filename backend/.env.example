# Copy this file to backend/.env and update the values as needed.

# Server
PORT=5000

# PostgreSQL (Prisma Postgres) — use the pooled connection string from the Prisma dashboard
DATABASE_URL="postgres://your-user:your-password@pooled.db.prisma.io:5432/postgres?sslmode=require"

# Optional direct connection for migrations or one-off admin scripts
DIRECT_URL="postgres://your-user:your-password@db.prisma.io:5432/postgres?sslmode=require"

# Auth — replace with a long random string before running
JWT_SECRET=change-me-to-a-long-random-string

# Frontend URL for email links (password reset, welcome).
# In production this MUST be the deployed frontend URL, or reset links break.
FRONTEND_URL=http://localhost:3000

# SMTP / Nodemailer
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
# and paste it WITHOUT spaces (Gmail displays it as "xxxx xxxx xxxx xxxx").
# Changing the Google account password revokes ALL existing app passwords.
# Production note: these values live in the Render dashboard, NOT in this file.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FAMILY=4
SMTP_REQUIRE_TLS=true
SMTP_DEBUG=false
SMTP_CONNECTION_TIMEOUT=15000
SMTP_GREETING_TIMEOUT=15000
SMTP_SOCKET_TIMEOUT=20000
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=MediHub
SMTP_FROM_EMAIL=no-reply@medihub.com

# AI provider (production: gemini, local fallback: ollama)
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=smollm:1.7b

# External APIs (optional — events and news pages fall back to empty results without these)
EVENTBRITE_TOKEN=
NEWS_API_KEY=
